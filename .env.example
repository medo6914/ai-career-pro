# ═══════════════════════════════════════════════════════════
#  AI Career Pro - Environment Variables
#  انسخ هذا الملف إلى .env واملأ القيم الحقيقية
#  cp .env.example .env
# ═══════════════════════════════════════════════════════════

# ─── AI Providers ───
# Google Gemini (AI الافتراضي)
# احصل على المفتاح: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# OpenAI ChatGPT (للباقة VIP)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key

# OpenRouter (GPT-4, Claude, وغيرها - مزود AI الافتراضي)
# https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your_openrouter_key_here

# ─── Stripe (فيزا، ماستركارد, Mada, Apple Pay - جميع البنوك العربية) ───
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
# Webhook: https://your-domain.com/api/webhook/stripe
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
# Stripe Price IDs (من Stripe Dashboard → Products → Create Product → Recurring)
# أنشئ منتج اشتراك لكل فئة في Stripe Dashboard واحصل على Price ID
# Pro = $9.99/شهر, VIP = $19.99/شهر
STRIPE_PRO_MONTHLY_PRICE_ID=price_your_pro_monthly_price_id
STRIPE_VIP_MONTHLY_PRICE_ID=price_your_vip_monthly_price_id

# ─── Paymob (Vodafone Cash, Etisalat Cash, جميع بنوك مصر والوطن العربي) ───
# سجل في: https://accept.paymob.com
# API Key من: Settings → Account → API Key
PAYMOB_API_KEY=your_paymob_api_key
# Integration ID من: Integrations → Card/Mobile Wallet → Integration ID
PAYMOB_INTEGRATION_ID=your_paymob_integration_id
# Iframe ID من: Integrations → Iframe → Iframe ID
PAYMOB_IFRAME_ID=your_paymob_iframe_id
# HMAC Secret من: Webhooks → HMAC Secret
PAYMOB_HMAC=your_paymob_hmac_secret

# ─── PayPal ───
# https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_SECRET=your_paypal_secret
PAYPAL_MODE=sandbox  # 'sandbox' للاختبار، 'live' للإنتاج

# ─── App ───
PORT=3000
NODE_ENV=development  # 'development' or 'production'
